{
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "https://api.anthropic.com/v1/messages"
    }
  ],
  "headers": [
    {
      "source": "/api/chat",
      "headers": [
        { "key": "x-api-key", "value": "$ANTHROPIC_API_KEY" },
        { "key": "anthropic-version", "value": "2023-06-01" },
        { "key": "content-type", "value": "application/json" }
      ]
    }
  ]
}